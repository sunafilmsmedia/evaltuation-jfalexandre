# Optionnel - sans cette clé, le rapport utilise un fallback déterministe
ANTHROPIC_API_KEY=

# URL du webhook CRM (Zapier, Make, ou endpoint custom)
# Reçoit un POST JSON avec { source, receivedAt, lead, scoring, answers }
# Si absent, les leads sont logués côté serveur uniquement.
CRM_WEBHOOK_URL=

# Secret optionnel envoyé en header X-Webhook-Secret
CRM_WEBHOOK_SECRET=
